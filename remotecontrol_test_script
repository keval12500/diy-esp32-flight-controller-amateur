    uint8_t crc = 0;
    for (uint8_t i = 0; i < len; i++) crc = tab[crc ^ *ptr++];
    return crc;
}

uint16_t cv(unsigned v) {
    static constexpr float scale  = (2012.f - 988.f) / (1811.f - 172.f);
    static constexpr float offset = 988.f - 172.f * scale;
    return (uint16_t)(scale * v + offset);
}

bool parse_byte(uint8_t c) {
    if (buf_i == 0) {
        if (c == CRSF_ADDRESS_FC) buf[buf_i++] = c;
    } else if (buf_i == 1) {
        if (c >= 2 && c <= (CRSF_FRAME_SIZE_MAX - 2)) { buf[buf_i++] = c; buf_len = c + 2; }
        else buf_i = 0;
    } else if (buf_i < buf_len - 1) {
        buf[buf_i++] = c;
    } else {
        buf[buf_i++] = c;
        uint8_t crc = crsf_crc8(buf + 2, buf[1] - 1);
        bool ok = (crc == buf[buf_len - 1]);
        buf_i = 0;
        if (!ok || buf[2] != CRSF_FRAMETYPE_RC || buf_len != 26) return false;
        last_frame_ms = millis();
        channel[0]  = cv((buf[3]  | buf[4]  << 8) & 0x7FF);
        channel[1]  = cv((buf[4]  >> 3 | buf[5]  << 5) & 0x7FF);
        channel[2]  = cv((buf[5]  >> 6 | buf[6]  << 2 | buf[7]  << 10) & 0x7FF);
        channel[3]  = cv((buf[7]  >> 1 | buf[8]  << 7) & 0x7FF);
        channel[4]  = cv((buf[8]  >> 4 | buf[9]  << 4) & 0x7FF);
        channel[5]  = cv((buf[9]  >> 7 | buf[10] << 1 | buf[11] << 9) & 0x7FF);
        channel[6]  = cv((buf[11] >> 2 | buf[12] << 6) & 0x7FF);
        channel[7]  = cv((buf[12] >> 5 | buf[13] << 3) & 0x7FF);
        return true;
    }
    return false;
}

void setup() {
    Serial.begin(115200);
    crsfSerial.begin(CRSF_BAUD, SERIAL_8N1, CRSF_RX_PIN, CRSF_TX_PIN);
    Serial.println("CRSF test started. Waiting for frames...");
}

uint32_t last_print = 0;

void loop() {
    bool got_frame = false;
    while (crsfSerial.available()) {
        if (parse_byte(crsfSerial.read())) got_frame = true;
    }

    // Print at ~10Hz regardless (shows connected status)
    if (millis() - last_print > 100) {
        last_print = millis();
        bool connected = (millis() - last_frame_ms) < 1000;

        if (!connected) {
            Serial.println("-- NO SIGNAL -- (check binding, wiring, baud)");
        } else {
            // CH1=Roll CH2=Pitch CH3=Thr CH4=Yaw CH5=Arm CH6=Mode
            Serial.printf("CH1(Roll):%4d  CH2(Pit):%4d  CH3(Thr):%4d  CH4(Yaw):%4d  CH5(Arm):%4d  CH6(Mode):%4d\n",
                channel[0], channel[1], channel[2], channel[3], channel[4], channel[5]);
        }
    }
}
